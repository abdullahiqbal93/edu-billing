<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
	<display-name>Pahana Edu Bookshop Billing System</display-name>

	<filter>
    <filter-name>CharacterEncodingFilter</filter-name>
    <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
    <init-param>
      <param-name>encoding</param-name>
      <param-value>UTF-8</param-value>
    </init-param>
    <init-param>
      <param-name>ignore</param-name>
      <param-value>false</param-value>
    </init-param>
  </filter>

  <filter>
    <filter-name>AuthenticationChecker</filter-name>
    <filter-class>com.pahana.util.AuthenticationChecker</filter-class>
  </filter>

  <filter-mapping>
    <filter-name>CharacterEncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>AuthenticationChecker</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>LoginController</servlet-name>
    <servlet-class>com.pahana.controller.LoginController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>DashboardController</servlet-name>
    <servlet-class>com.pahana.controller.DashboardController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>CustomerController</servlet-name>
    <servlet-class>com.pahana.controller.CustomerController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ItemController</servlet-name>
    <servlet-class>com.pahana.controller.ItemController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>BillController</servlet-name>
    <servlet-class>com.pahana.controller.BillController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>HelpController</servlet-name>
    <servlet-class>com.pahana.controller.HelpController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>LogoutController</servlet-name>
    <servlet-class>com.pahana.controller.LogoutController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>SettingsController</servlet-name>
    <servlet-class>com.pahana.controller.SettingsController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>EmailController</servlet-name>
    <servlet-class>com.pahana.controller.EmailController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ReportController</servlet-name>
    <servlet-class>com.pahana.controller.ReportController</servlet-class>
  </servlet>
  

  <servlet-mapping>
    <servlet-name>LoginController</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>DashboardController</servlet-name>
    <url-pattern>/dashboard</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>CustomerController</servlet-name>
    <url-pattern>/customer</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ItemController</servlet-name>
    <url-pattern>/item</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>BillController</servlet-name>
    <url-pattern>/bill</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>HelpController</servlet-name>
    <url-pattern>/help</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>LogoutController</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>SettingsController</servlet-name>
    <url-pattern>/settings</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>EmailController</servlet-name>
    <url-pattern>/email/receipt</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ReportController</servlet-name>
    <url-pattern>/report</url-pattern>
  </servlet-mapping>
</web-app>
